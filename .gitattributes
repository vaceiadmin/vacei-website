# Git LFS — MP4s under public/assets/videos/
# One-time: git lfs install
# After push, upload LFS blobs: npm run git:lfs-push-all
# GitHub web UI shows a small "version https://git-lfs…" file for LFS paths — that is normal; the real video is in Git LFS storage.
# Vercel: enable Git LFS in project settings if you keep other *.mp4 in LFS; hero banner is plain Git so it always deploys.
public/assets/videos/*.mp4 filter=lfs diff=lfs merge=lfs -text
# Plain Git blobs (not LFS) — small files or ones that must exist on hosts without Git LFS (e.g. Vercel if LFS is off)
public/assets/videos/banner-gip-2-new.mp4 -filter -diff -merge
public/assets/videos/hero-banner-v1.mp4 -filter -diff -merge
public/assets/videos/Vacei*X2V2.mp4 -filter -diff -merge
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
